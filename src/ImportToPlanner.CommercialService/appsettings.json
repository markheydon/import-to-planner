{
  "Storage": {
    "TenantMetadataTable": "TenantOperationalMetadata",
    "CommercialAccountsTable": "CommercialAccounts",
    "CommercialAuditTable": "CommercialAccountAuditEvents"
  },
  "Features": {
    "CommercialMode": {
      "Enabled": false,
      "RetentionSweepEnabled": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
