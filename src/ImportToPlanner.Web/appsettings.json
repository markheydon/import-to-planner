{
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "__REPLACE_WITH_TENANT_ID__",
    "ClientId": "__REPLACE_WITH_CLIENT_ID__",
    "CallbackPath": "/signin-oidc",
    "ClientCertificates": [
      {
        "SourceType": "Path",
        "CertificateDiskPath": "__REPLACE_WITH_CERTIFICATE_PATH__",
        "CertificatePassword": "__REPLACE_WITH_CERTIFICATE_PASSWORD__"
      }
    ]
  },
  "DownstreamApis": {
    "MicrosoftGraph": {
      "BaseUrl": "https://graph.microsoft.com/beta",
      "Scopes": [
        "User.Read",
        "Group.Read.All",
        "GroupMember.Read.All",
        "Tasks.ReadWrite"
      ]
    }
  },
  "PlannerGateway": {
    "UseGraph": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
