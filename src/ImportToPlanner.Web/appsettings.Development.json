{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Identity.Web": "Warning",
      "Microsoft.Identity.Web.TokenAcquisition": "Warning"
    }
  },
  "DeploymentMode": {
    "Mode": "HostedSharedMultiTenant",
    "AuthorityTenant": "organizations",
    "InitialHostedReplicaPolicy": "SingleActiveReplica"
  },
  "HostedStorage": {
    "Enabled": true,
    "ConnectionString": "UseDevelopmentStorage=true",
    "TenantMetadataTable": "TenantOperationalMetadata",
    "DataProtectionContainer": "dataprotection",
    "DataProtectionBlob": "keys.xml"
  }
}
