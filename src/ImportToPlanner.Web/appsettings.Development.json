{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Identity.Web": "Warning",
      "Microsoft.Identity.Web.TokenAcquisition": "Warning"
    }
  },
  "Storage": {
    "TenantMetadataTable": "TenantOperationalMetadata",
    "CommercialAccountsTable": "CommercialAccounts",
    "CommercialAuditTable": "CommercialAccountAuditEvents",
    "DataProtectionContainer": "dataprotection",
    "DataProtectionBlob": "keys.xml"
  },
  "Features": {
    "CommercialMode": {
      "Enabled": false
    }
  }
}
