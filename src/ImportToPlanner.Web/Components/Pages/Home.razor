@page "/"
@inject ICsvImportParser CsvImportParser
@inject IImportPlannerOrchestrator ImportPlannerOrchestrator
@inject IPlannerGateway PlannerGateway
@inject IConfiguration Configuration
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject ILogger<Home> Logger

<PageTitle>Import To Planner</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16" class="import-grid">
	<FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
		<FluentLabel Typo="Typography.PaneHeader">Import Input</FluentLabel>

		<FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
			<FluentSelect Items="@containers" OptionText="@(container => container is null ? string.Empty : $"{container.DisplayName} ({container.Type})")"
						  OptionSelected="@(container => container?.Id == selectedContainer?.Id)"
						  SelectedOption="@selectedContainer"
						  SelectedOptionChanged="@((PlannerContainer? container) => OnSelectedContainerChanged(container))"
						  Label="Container" />

			<FluentTextField Value="@planName" ValueChanged="@((string? value) => OnPlanNameChanged(value))"
							 Immediate="true" Label="Plan Name" Required="true" Maxlength="200" />

			<FluentInputFile Id="csv-file-input" AnchorId="csv-file-button" OnInputFileChange="OnFileChangedAsync"
							 Accept=".csv,text/csv" MaximumFileCount="1" DragDropZoneVisible="false" />
			<FluentSwitch Value="@ignoreExtraColumns"
						  ValueChanged="@((bool value) => OnIgnoreExtraColumnsChanged(value))"
						  Label="Ignore extra columns" />
			<FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8"
						 VerticalAlignment="VerticalAlignment.Center">
				<FluentButton Id="csv-file-button" Appearance="Appearance.Outline">Browse CSV file</FluentButton>
				<FluentLabel>@selectedFileName</FluentLabel>
			</FluentStack>

			<FluentStack Orientation="Orientation.Horizontal" HorizontalGap="10">
				<FluentButton Appearance="Appearance.Accent" Disabled="@(!canValidate)" OnClick="@BuildPreviewAsync">
					Validate And Preview
				</FluentButton>
				<FluentButton Appearance="Appearance.Neutral" Disabled="@(!canExecute)" OnClick="@ExecuteAsync">
					Confirm And Execute
				</FluentButton>
			</FluentStack>

			@if (!string.IsNullOrWhiteSpace(statusMessage))
			{
				<FluentMessageBar Intent="@StatusMessageIntent" AllowDismiss="false">@statusMessage</FluentMessageBar>
			}

			@if (parseErrors.Count > 0)
			{
				<FluentLabel Typo="Typography.Header">Validation Errors</FluentLabel>
				<FluentDataGrid Items="@parseErrors.AsQueryable()" TGridItem="ImportValidationError">
					<PropertyColumn Property="@(error => error.RowNumber)" Title="Row" />
					<PropertyColumn Property="@(error => error.Field)" Title="Field" />
					<PropertyColumn Property="@(error => error.Message)" Title="Message" />
				</FluentDataGrid>
			}
		</FluentStack>
	</FluentStack>

	@if (preview is not null)
	{
		<FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
			<FluentLabel Typo="Typography.PaneHeader">Dry-Run Preview</FluentLabel>

			<FluentLabel Typo="Typography.Subject">Plan action: @preview.PlanAction</FluentLabel>

			<FluentLabel Typo="Typography.Header">Bucket Actions</FluentLabel>
			<FluentDataGrid Items="@preview.BucketActions.AsQueryable()"
							TGridItem="KeyValuePair<string, PlannedEntityAction>">
				<PropertyColumn Property="@(action => action.Key)" Title="Bucket" />
				<PropertyColumn Property="@(action => action.Value)" Title="Action" />
			</FluentDataGrid>

			<FluentLabel Typo="Typography.Header">Task Actions</FluentLabel>
			<FluentDataGrid Items="@preview.TaskActions.AsQueryable()" TGridItem="ImportTaskPlanItem">
				<PropertyColumn Property="@(task => task.RowNumber)" Title="Row" />
				<PropertyColumn Property="@(task => task.TaskName)" Title="Task" />
				<PropertyColumn Property="@(task => task.Bucket)" Title="Bucket" />
				<PropertyColumn Property="@(task => FormatGoals(task.Goals))" Title="Goals" />
				<PropertyColumn Property="@(task => task.Action)" Title="Action" />
				<PropertyColumn Property="@(task => task.Reason)" Title="Reason" />
			</FluentDataGrid>
		</FluentStack>
	}

	@if (executionResult is not null)
	{
		<FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
			<FluentLabel Typo="Typography.PaneHeader">Execution Report</FluentLabel>

			<FluentLabel Typo="Typography.Header">Created</FluentLabel>
			<FluentDataGrid Items="@executionResult.Created.AsQueryable()" TGridItem="string">
				<PropertyColumn Property="@(item => item)" Title="Item" />
			</FluentDataGrid>

			<FluentLabel Typo="Typography.Header">Reused Or Skipped</FluentLabel>
			<FluentDataGrid Items="@executionResult.ReusedOrSkipped.AsQueryable()" TGridItem="string">
				<PropertyColumn Property="@(item => item)" Title="Item" />
			</FluentDataGrid>

			<FluentLabel Typo="Typography.Header">Errors</FluentLabel>
			@if (executionResult.Errors.Count == 0)
			{
				<FluentMessageBar Intent="MessageIntent.Success" AllowDismiss="false">None</FluentMessageBar>
			}
			else
			{
				<FluentDataGrid Items="@executionResult.Errors.AsQueryable()" TGridItem="string">
					<PropertyColumn Property="@(item => item)" Title="Error" />
				</FluentDataGrid>
			}

			<FluentLabel Typo="Typography.Header">Manual Actions</FluentLabel>
			@if (executionResult.ManualActions.Count == 0)
			{
				<FluentMessageBar Intent="MessageIntent.Success" AllowDismiss="false">None</FluentMessageBar>
			}
			else
			{
				<FluentDataGrid Items="@executionResult.ManualActions.AsQueryable()" TGridItem="ManualAction">
					<PropertyColumn Property="@(item => item.ActionType)" Title="Action Type" />
					<PropertyColumn Property="@(item => item.GoalName)" Title="Goal" />
					<PropertyColumn Property="@(item => item.TaskName)" Title="Task" />
					<PropertyColumn Property="@(item => item.Details)" Title="Details" />
				</FluentDataGrid>
			}
		</FluentStack>
	}
</FluentStack>

@code {
	private readonly List<PlannerContainer> containers = [];
	private readonly List<ImportValidationError> parseErrors = [];

	private PlannerContainer? selectedContainer;
	private string planName = string.Empty;
	private string csvContent = string.Empty;
	private string selectedFileName = "No file selected.";
	private string? statusMessage;
	private bool isBusy;
	private bool ignoreExtraColumns = true;

	private ImportPlanPreview? preview;
	private ImportExecutionResult? executionResult;
	private ImportRequest? currentRequest;

	private bool canValidate => !isBusy
		&& selectedContainer is not null
		&& !string.IsNullOrWhiteSpace(planName)
		&& !string.IsNullOrWhiteSpace(csvContent);
	private bool canExecute => !isBusy && preview is not null && currentRequest is not null;
	private MessageIntent StatusMessageIntent => parseErrors.Count > 0
		? MessageIntent.Error
		: executionResult is null
			? MessageIntent.Info
			: executionResult.Errors.Count > 0
				? MessageIntent.Warning
				: MessageIntent.Success;

	protected override async Task OnInitializedAsync()
	{
		var useGraph = Configuration.GetValue<bool>("PlannerGateway:UseGraph");
		if (useGraph)
		{
			var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
			var isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
			if (!isAuthenticated)
			{
				NavigationManager.NavigateTo("MicrosoftIdentity/Account/SignIn", forceLoad: true);
				return;
			}
		}

		try
		{
			// Guard against duplicate loads: clear before adding to ensure single initialization.
			containers.Clear();
			var loadedContainers = await PlannerGateway.GetAvailableContainersAsync(CancellationToken.None);
			containers.AddRange(loadedContainers);
			if (containers.Count > 0)
			{
				selectedContainer = containers[0];
			}
		}
		catch (Microsoft.Identity.Web.MicrosoftIdentityWebChallengeUserException)
		{
			NavigationManager.NavigateTo("MicrosoftIdentity/Account/SignIn", forceLoad: true);
		}
	}

	private async Task OnFileChangedAsync(InputFileChangeEventArgs args)
	{
		ResetFlowState();

		var file = args.File;
		selectedFileName = file.Name;

		await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
		using var reader = new StreamReader(stream);
		csvContent = await reader.ReadToEndAsync();

		statusMessage = "CSV file loaded. Click Validate And Preview.";
	}

	private void OnSelectedContainerChanged(PlannerContainer? container)
	{
		if (selectedContainer?.Id == container?.Id)
		{
			return;
		}

		selectedContainer = container;
		ResetFlowState();
	}

	private void OnPlanNameChanged(string? value)
	{
		var normalizedValue = value ?? string.Empty;
		if (string.Equals(planName, normalizedValue, StringComparison.Ordinal))
		{
			return;
		}

		planName = normalizedValue;
		ResetFlowState();
	}

	private void OnIgnoreExtraColumnsChanged(bool value)
	{
		if (ignoreExtraColumns == value)
		{
			return;
		}

		ignoreExtraColumns = value;
		ResetFlowState();
	}

	private void ResetFlowState()
	{
		parseErrors.Clear();
		preview = null;
		currentRequest = null;
		executionResult = null;
		statusMessage = null;
	}

	private async Task BuildPreviewAsync()
	{
		if (isBusy)
		{
			return;
		}

		parseErrors.Clear();
		preview = null;
		executionResult = null;
		statusMessage = null;

		if (selectedContainer is null)
		{
			parseErrors.Add(new ImportValidationError(0, "Container", "A container must be selected."));
			return;
		}

		if (string.IsNullOrWhiteSpace(planName))
		{
			parseErrors.Add(new ImportValidationError(0, "Plan Name", "Plan name is required."));
			return;
		}

		if (string.IsNullOrWhiteSpace(csvContent))
		{
			parseErrors.Add(new ImportValidationError(0, "File", "Upload a CSV file first."));
			return;
		}

		isBusy = true;
		try
		{
			var parseResult = await CsvImportParser.ParseAsync(csvContent, CancellationToken.None, ignoreExtraColumns);
			parseErrors.AddRange(parseResult.ValidationErrors);

			if (parseResult.HasErrors)
			{
				statusMessage = "Validation failed. Fix the reported issues and retry.";
				return;
			}

			currentRequest = new ImportRequest(selectedContainer.Id, planName.Trim(), parseResult.Rows);
			preview = await ImportPlannerOrchestrator.BuildPreviewAsync(currentRequest, CancellationToken.None);
			statusMessage = "Preview generated. Review actions, then confirm execution.";
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Preview generation failed.");
			parseErrors.Add(new ImportValidationError(0, "System", "Preview generation failed due to an unexpected system error."));
			statusMessage = "Preview generation failed.";
		}
		finally
		{
			isBusy = false;
		}
	}

	private async Task ExecuteAsync()
	{
		if (!canExecute)
		{
			return;
		}

		isBusy = true;
		statusMessage = null;
		try
		{
			executionResult = await ImportPlannerOrchestrator.ExecuteAsync(
				currentRequest!,
				preview!,
				CancellationToken.None);

			statusMessage = executionResult.Errors.Count == 0
				? "Execution completed successfully."
				: "Execution completed with errors.";
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Execution failed.");
			executionResult = new ImportExecutionResult
			{
				Created = [],
				ReusedOrSkipped = [],
				Errors = ["Execution failed due to an unexpected system error. Check logs and retry."],
				ManualActions = [],
			};

			statusMessage = "Execution failed.";
		}
		finally
		{
			isBusy = false;
		}
	}

	private static string? FormatGoals(IReadOnlyList<string>? goals)
	{
		return goals is { Count: > 0 } ? string.Join(", ", goals) : string.Empty;
	}
}
