@page "/"
@using ImportToPlanner.Application.Exceptions
@using Microsoft.AspNetCore.WebUtilities
@inject ImportWorkflowCoordinator WorkflowCoordinator
@inject WorkflowCoordinationState WorkflowState
@inject IConfiguration Configuration
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject ILogger<Home> Logger

<PageTitle>Import To Planner</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
    <MudStack Spacing="4">
        <MudPaper Elevation="0" Outlined="true" Class="pa-4 pa-md-6">
            <MudGrid Spacing="3">
                <MudItem xs="12" md="7">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.h3">CSV to Planner Import</MudText>
                        <MudText Typo="Typo.body1">
                            Import a CSV into one Planner plan, then review each step before execution.
                        </MudText>
                    </MudStack>
                </MudItem>
                <MudItem xs="12" md="5">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Spacing="1" Wrap="Wrap.Wrap">
                        <MudMenu Icon="@GetThemeMenuIcon()" Color="Color.Inherit" Variant="Variant.Text" Dense="true" AriaLabel="Theme mode" Disabled="@(ThemeState is null)">
                            <MudMenuItem OnClick="@(() => SetThemeModeAsync(ThemeMode.Auto))">@GetThemeOptionLabel(ThemeMode.Auto)</MudMenuItem>
                            <MudMenuItem OnClick="@(() => SetThemeModeAsync(ThemeMode.Light))">@GetThemeOptionLabel(ThemeMode.Light)</MudMenuItem>
                            <MudMenuItem OnClick="@(() => SetThemeModeAsync(ThemeMode.Dark))">@GetThemeOptionLabel(ThemeMode.Dark)</MudMenuItem>
                        </MudMenu>
                        <AuthorizeView>
                            <Authorized Context="authState">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                                    <MudText Typo="Typo.body2">@authState.User.Identity?.Name</MudText>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Inherit" Size="Size.Small" OnClick="OnSignOutClicked">Sign out</MudButton>
                                </MudStack>
                            </Authorized>
                            <NotAuthorized>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="OnSignInClicked">Sign in</MudButton>
                            </NotAuthorized>
                        </AuthorizeView>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudStack Spacing="3">
            @if (isBusy)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }

            @if (!string.IsNullOrWhiteSpace(statusMessage) && !showUnsupportedAccountGuidance)
            {
                <MudAlert Severity="@StatusMessageSeverity" Dense="true">@statusMessage</MudAlert>
            }

            @if (isTenantContextMismatch)
            {
                <MudAlert Severity="Severity.Warning" Dense="true">
                    Tenant context changed since your previous sign-in. The workflow now uses the current tenant context and requires a fresh preview.
                </MudAlert>
            }

            @if (showAdminConsentGuidance)
            {
                <MudAlert Severity="Severity.Warning" Dense="true">
                    Hosted access requires administrator consent for this tenant. Ask your Microsoft 365 administrator to approve access, then sign in again.
                </MudAlert>
            }

            @if (showUnsupportedAccountGuidance)
            {
                <MudAlert Severity="Severity.Error" Dense="true">
                    Unsupported account type. Sign in with a supported work or school account.
                </MudAlert>
            }

            <MudPaper Elevation="@GetStepElevation(1)" Outlined="true" Class="@GetStepClass(1)">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudAvatar Color="@GetStepAvatarColour(1)">@GetStepAvatarContent(1)</MudAvatar>
                    <MudText Typo="Typo.h6">Step 1 · Select Container</MudText>
                </MudStack>
                @if (IsStepComplete(1))
                {
                    <MudChip T="string" Color="@GetStepSummaryColour(1)" Variant="Variant.Outlined" Size="Size.Small" Icon="@Icons.Material.Filled.CheckCircle" Class="mt-1">
                        @GetStepSummary(1)
                    </MudChip>
                }

                <MudStack Spacing="2" Class="mt-3">
                    <MudAlert Severity="Severity.Info" Dense="true">
                        Create your target plan first in Planner (Personal or Microsoft 365 Group), then select it below.
                    </MudAlert>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudAutocomplete T="PlannerContainer"
                                         Value="@selectedContainer"
                                         ValueChanged="OnSelectedContainerChangedAsync"
                                         SearchFunc="SearchContainers"
                                         ToStringFunc="FormatContainer"
                                         Label="Container"
                                         Placeholder="Search or select a container"
                                         Variant="Variant.Outlined"
                                         Clearable="true"
                                         Dense="true"
                                         CoerceValue="false"
                                         ResetValueOnEmptyText="true"
                                         Disabled="@isBusy" />
                        <MudButton Variant="Variant.Text" Color="Color.Inherit" Disabled="@isBusy" OnClick="@RefreshContainersAsync">
                            Refresh containers
                        </MudButton>
                    </MudStack>

                    @if (isUsingGraphGateway && noGroupsFound)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            No groups found. Ensure you are a member of at least one Microsoft 365 group.
                        </MudAlert>
                    }
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="@GetStepElevation(2)" Outlined="true" Class="@GetStepClass(2)">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudAvatar Color="@GetStepAvatarColour(2)">@GetStepAvatarContent(2)</MudAvatar>
            <MudText Typo="Typo.h6">Step 2 · Select Plan</MudText>
        </MudStack>
        @if (IsStepComplete(2))
        {
            <MudChip T="string" Color="@GetStepSummaryColour(2)" Variant="Variant.Outlined" Size="Size.Small" Icon="@Icons.Material.Filled.CheckCircle" Class="mt-1">
                @GetStepSummary(2)
            </MudChip>
        }

        <MudStack Spacing="2" Class="mt-3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudAutocomplete T="PlannerPlan"
                                 Value="@selectedPlan"
                                 ValueChanged="OnSelectedPlanChangedAsync"
                                 SearchFunc="SearchPlans"
                                 ToStringFunc="FormatPlan"
                                 Label="Plan"
                                 Placeholder="Search or select a plan"
                                 Variant="Variant.Outlined"
                                 Clearable="true"
                                 Dense="true"
                                 CoerceValue="false"
                                 ResetValueOnEmptyText="true"
                                 Disabled="@(isBusy || selectedContainer is null)" />
                <MudButton Variant="Variant.Text" Color="Color.Inherit" Disabled="@(isBusy || selectedContainer is null)" OnClick="@RefreshPlansAsync">
                    Refresh plans
                </MudButton>
            </MudStack>

            @if (selectedContainer is not null && plans.Count == 0)
            {
                <MudAlert Severity="Severity.Warning" Dense="true">
                    No plans were found for this container. Create a plan in Planner, then click Refresh plans.
                </MudAlert>
            }
        </MudStack>
    </MudPaper>

            <MudPaper Elevation="@GetStepElevation(3)" Outlined="true" Class="@GetStepClass(3)">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudAvatar Color="@GetStepAvatarColour(3)">@GetStepAvatarContent(3)</MudAvatar>
            <MudText Typo="Typo.h6">Step 3 · Upload CSV and Options</MudText>
        </MudStack>
        @if (IsStepComplete(3))
        {
            <MudChip T="string" Color="@GetStepSummaryColour(3)" Variant="Variant.Outlined" Size="Size.Small" Icon="@Icons.Material.Filled.CheckCircle" Class="mt-1">
                @GetStepSummary(3)
            </MudChip>
        }

        <MudStack Spacing="2" Class="mt-3">
            <MudFileUpload T="IBrowserFile"
                           @ref="csvFileUpload"
                           FilesChanged="OnFileChangedAsync"
                           Accept=".csv,text/csv"
                           MaximumFileCount="1"
                           Hidden="true"
                           Disabled="@(isBusy || IsStepLocked(3))">
                <CustomContent>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.UploadFile"
                               OnClick="OpenCsvFilePickerAsync"
                               Disabled="@(isBusy || IsStepLocked(3))">
                        Choose CSV file
                    </MudButton>
                </CustomContent>
                <SelectedTemplate>
                    @if (context is not null)
                    {
                        <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small" Icon="@Icons.Material.Filled.Description">
                            @context.Name
                        </MudChip>
                    }
                </SelectedTemplate>
            </MudFileUpload>
            <MudText Typo="Typo.body2">Selected file: @selectedFileName</MudText>
            <MudSwitch T="bool"
                       Value="@ignoreExtraColumns"
                       ValueChanged="@OnIgnoreExtraColumnsChanged"
                       Color="Color.Primary"
                       Label="Ignore extra columns"
                       Disabled="@(isBusy || IsStepLocked(3))" />
        </MudStack>
    </MudPaper>

            <MudPaper Elevation="@GetStepElevation(4)" Outlined="true" Class="@GetStepClass(4)">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudAvatar Color="@GetStepAvatarColour(4)">@GetStepAvatarContent(4)</MudAvatar>
            <MudText Typo="Typo.h6">Step 4 · Validate and Preview</MudText>
        </MudStack>
        @if (IsStepComplete(4))
        {
            <MudChip T="string" Color="@GetStepSummaryColour(4)" Variant="Variant.Outlined" Size="Size.Small" Icon="@Icons.Material.Filled.CheckCircle" Class="mt-1">
                @GetStepSummary(4)
            </MudChip>
        }

        <MudStack Spacing="2" Class="mt-3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!canValidate)" OnClick="@BuildPreviewAsync">
                Validate and preview
            </MudButton>

            @if (isPreviewStale)
            {
                <MudAlert Severity="Severity.Warning" Dense="true">
                    Preview is stale because Planner state changed. Generate a fresh preview before execution.
                </MudAlert>
            }

            @if (parseErrors.Count > 0)
            {
                <MudText Typo="Typo.subtitle2">Validation errors</MudText>
                <MudDataGrid Items="@parseErrors" T="ImportValidationError" Dense="true" ReadOnly="true">
                    <Columns>
                        <PropertyColumn Property="@(error => error.RowNumber)" Title="Row" />
                        <PropertyColumn Property="@(error => error.Field)" Title="Field" />
                        <PropertyColumn Property="@(error => error.Message)" Title="Message" />
                    </Columns>
                </MudDataGrid>
            }

            @if (preview is not null)
            {
                <MudText Typo="Typo.subtitle2">Dry-run preview</MudText>
                <MudText Typo="Typo.body2">Plan action: Reuse existing plan</MudText>

                @if (preview.Preview.PlanId is not null)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">
                        Plan selected. <a href="https://planner.cloud.microsoft/webui/plan/@preview.Preview.PlanId" target="_blank"
                                          rel="noopener noreferrer">Open in Planner</a>
                    </MudAlert>
                }

                <MudText Typo="Typo.subtitle2">Bucket actions</MudText>
                <MudSimpleTable Dense="true" Hover="true" Elevation="0">
                    <thead>
                        <tr>
                            <th>Bucket</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var action in preview.BucketActions)
                        {
                            <tr>
                                <td>@action.BucketName</td>
                                <td>@action.Action</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>

                <MudText Typo="Typo.subtitle2">Task actions</MudText>
                <MudDataGrid Items="@preview.TaskActions" T="ImportTaskActionViewModel" Dense="true" ReadOnly="true">
                    <Columns>
                        <PropertyColumn Property="@(task => task.RowNumber)" Title="Row" />
                        <PropertyColumn Property="@(task => task.TaskName)" Title="Task" />
                        <PropertyColumn Property="@(task => task.Bucket)" Title="Bucket" />
                        <PropertyColumn Property="@(task => task.Goals)" Title="Goals" />
                        <PropertyColumn Property="@(task => task.Action)" Title="Action" />
                        <PropertyColumn Property="@(task => task.Reason)" Title="Reason" />
                    </Columns>
                </MudDataGrid>
            }
        </MudStack>
    </MudPaper>

            <MudPaper Elevation="@GetStepElevation(5)" Outlined="true" Class="@GetStepClass(5)">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudAvatar Color="@GetStepAvatarColour(5)">@GetStepAvatarContent(5)</MudAvatar>
            <MudText Typo="Typo.h6">Step 5 · Confirm and Execute</MudText>
        </MudStack>
        @if (IsStepComplete(5))
        {
            <MudChip T="string" Color="@GetStepSummaryColour(5)" Variant="Variant.Outlined" Size="Size.Small" Icon="@Icons.Material.Filled.CheckCircle" Class="mt-1">
                @GetStepSummary(5)
            </MudChip>
        }

        <MudStack Spacing="2" Class="mt-3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!canExecute)" OnClick="@ExecuteAsync">
                Confirm and execute
            </MudButton>
            <HomeExecutionReport ExecutionResult="@executionResult" />
        </MudStack>
    </MudPaper>
        </MudStack>
    </MudStack>
</MudContainer>

@code {
    private const string InteractiveTokenAcquisitionRequiredMessage = "Sign-in completed, but Microsoft Graph access still needs confirmation. Sign out and sign in again if access does not continue.";
    private const string TokenReauthenticationQueryKey = "tokenReauth";

    [CascadingParameter]
    private ThemeState? ThemeState { get; set; }

    private List<PlannerContainer> containers => WorkflowState.Containers;

    private List<PlannerPlan> plans => WorkflowState.Plans;

    private List<ImportValidationError> parseErrors => WorkflowState.ParseErrors;

    private PlannerContainer? selectedContainer
    {
        get => WorkflowState.SelectedContainer;
        set => WorkflowState.SelectedContainer = value;
    }

    private PlannerPlan? selectedPlan
    {
        get => WorkflowState.SelectedPlan;
        set => WorkflowState.SelectedPlan = value;
    }

    private string csvContent
    {
        get => WorkflowState.CsvContent;
        set => WorkflowState.CsvContent = value;
    }

    private string selectedFileName
    {
        get => WorkflowState.SelectedFileName;
        set => WorkflowState.SelectedFileName = value;
    }

    private string? statusMessage
    {
        get => WorkflowState.StatusMessage;
        set => WorkflowState.StatusMessage = value;
    }

    private Severity statusMessageSeverity
    {
        get => WorkflowState.StatusSeverity;
        set => WorkflowState.StatusSeverity = value;
    }

    private bool isBusy
    {
        get => WorkflowState.IsBusy;
        set => WorkflowState.IsBusy = value;
    }

    private bool isUsingGraphGateway
    {
        get => WorkflowState.IsUsingGraphGateway;
        set => WorkflowState.IsUsingGraphGateway = value;
    }

    private bool noGroupsFound
    {
        get => WorkflowState.NoGroupsFound;
        set => WorkflowState.NoGroupsFound = value;
    }

    private bool ignoreExtraColumns
    {
        get => WorkflowState.IgnoreExtraColumns;
        set => WorkflowState.IgnoreExtraColumns = value;
    }

    private bool isPreviewStale
    {
        get => WorkflowState.IsPreviewStale;
        set => WorkflowState.IsPreviewStale = value;
    }

    private bool isTenantContextMismatch
    {
        get => WorkflowState.IsTenantContextMismatch;
        set => WorkflowState.IsTenantContextMismatch = value;
    }

    private bool showAdminConsentGuidance =>
        !string.IsNullOrWhiteSpace(statusMessage)
        && statusMessage.Contains("administrator consent", StringComparison.OrdinalIgnoreCase);

    private bool showUnsupportedAccountGuidance =>
        !string.IsNullOrWhiteSpace(statusMessage)
        && statusMessage.Contains("unsupported account", StringComparison.OrdinalIgnoreCase);

    private ImportPlanningViewModel? preview => WorkflowState.PlanningViewModel;

    private ImportExecutionReportViewModel? executionResult => WorkflowState.ExecutionReport;

    private ImportPlanningRequest? currentRequest
    {
        get => WorkflowState.CurrentPlanningRequest;
        set => WorkflowState.CurrentPlanningRequest = value;
    }

    private bool IsCurrentSelectionInSyncWithRequest()
        => selectedContainer is not null
           && selectedPlan is not null
           && currentRequest is not null
           && string.Equals(selectedContainer.Id, currentRequest.ContainerId, StringComparison.Ordinal)
           && string.Equals(selectedPlan.Id, currentRequest.PlanId, StringComparison.Ordinal);

    private bool canValidate
        => !isBusy
           && selectedContainer is not null
           && selectedPlan is not null
           && !string.IsNullOrWhiteSpace(csvContent);

    private bool canExecute
        => !isBusy
           && preview is not null
           && currentRequest is not null
           && !isPreviewStale
           && IsCurrentSelectionInSyncWithRequest();

    private Severity StatusMessageSeverity
        => parseErrors.Count > 0
           ? Severity.Error
           : executionResult is null
               ? statusMessageSeverity
               : executionResult.Errors.Count > 0
                   ? Severity.Warning
                   : Severity.Success;

    private int? ActiveStep
    {
        get
        {
            for (var step = 1; step <= 5; step++)
            {
                if (!IsStepLocked(step) && !IsStepComplete(step))
                {
                    return step;
                }
            }

            return null;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var hasAuthErrorFromQuery = false;
        var hasTokenReauthenticationQuery = false;
        var query = new Uri(NavigationManager.Uri).Query;
        if (!string.IsNullOrWhiteSpace(query))
        {
            var parsedQuery = QueryHelpers.ParseQuery(query);
            if (parsedQuery.TryGetValue("authError", out var authErrorValues)
                && !string.IsNullOrWhiteSpace(authErrorValues))
            {
                hasAuthErrorFromQuery = true;
                SetStatus(authErrorValues.ToString(), Severity.Warning);
            }

            if (parsedQuery.TryGetValue(TokenReauthenticationQueryKey, out var tokenReauthenticationValues)
                && string.Equals(tokenReauthenticationValues.ToString(), "1", StringComparison.Ordinal))
            {
                hasTokenReauthenticationQuery = true;
            }
        }

        isUsingGraphGateway = Configuration.GetValue<bool>("PlannerGateway:UseGraph");
        if (isUsingGraphGateway)
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
            if (!isAuthenticated)
            {
                if (hasAuthErrorFromQuery)
                {
                    // Keep the user on the page with the auth error message instead of re-triggering sign-in.
                    return;
                }

                NavigationManager.NavigateTo("MicrosoftIdentity/Account/SignIn", forceLoad: true);
                return;
            }
        }

        try
        {
            await WorkflowCoordinator.LoadContainersAsync(WorkflowState, CancellationToken.None);

            if (hasTokenReauthenticationQuery)
            {
                RemoveTokenReauthenticationQueryFlag();
            }
        }
        catch (Exception ex)
        {
            if (await TryHandleAuthenticationChallengeAsync(ex))
            {
                return;
            }

            Logger.LogError(ex, "Failed to load available containers during initialisation.");
            SetStatus(ToUserSafePlannerMessage(ex), Severity.Error);
        }
    }

    private void OnSignInClicked()
    {
        NavigationManager.NavigateTo("MicrosoftIdentity/Account/SignIn", forceLoad: true);
    }

    private void OnSignOutClicked()
    {
        var returnUrl = Uri.EscapeDataString(new Uri(NavigationManager.BaseUri).PathAndQuery);
        NavigationManager.NavigateTo($"MicrosoftIdentity/Account/SignOut?returnUrl={returnUrl}", forceLoad: true);
    }

    private Task SetThemeModeAsync(ThemeMode mode)
    {
        if (ThemeState is null)
        {
            Logger.LogWarning("Theme mode change ignored because no ThemeState cascade is available.");
            return Task.CompletedTask;
        }

        return ThemeState.SetThemeMode(mode);
    }

    private string GetThemeMenuIcon()
        => (ThemeState?.ThemeMode ?? ThemeMode.Auto) switch
        {
            ThemeMode.Auto => Icons.Material.Filled.BrightnessAuto,
            ThemeMode.Light => Icons.Material.Filled.LightMode,
            ThemeMode.Dark => Icons.Material.Filled.DarkMode,
            _ => Icons.Material.Filled.BrightnessAuto,
        };

    private string GetThemeOptionLabel(ThemeMode mode)
    {
        var label = GetThemeModeDisplayName(mode);
        var activeMode = ThemeState?.ThemeMode ?? ThemeMode.Auto;
        return activeMode == mode ? $"✓ {label}" : label;
    }

    private static string GetThemeModeDisplayName(ThemeMode mode)
        => mode switch
        {
            ThemeMode.Auto => "Auto",
            ThemeMode.Light => "Light",
            ThemeMode.Dark => "Dark",
            _ => "Auto",
        };

    private async Task RefreshContainersAsync()
    {
        if (isBusy)
        {
            return;
        }

        isBusy = true;
        try
        {
            await WorkflowCoordinator.LoadContainersAsync(WorkflowState, CancellationToken.None);

            SetStatus("Container list refreshed.", Severity.Success);
        }
        catch (Exception ex)
        {
            if (await TryHandleAuthenticationChallengeAsync(ex))
            {
                return;
            }

            Logger.LogError(ex, "Failed to refresh containers.");
            SetStatus(ToUserSafePlannerMessage(ex), Severity.Error);
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task RefreshPlansAsync()
    {
        if (isBusy || selectedContainer is null)
        {
            return;
        }

        isBusy = true;
        try
        {
            await WorkflowCoordinator.LoadPlansAsync(WorkflowState, CancellationToken.None);
            SetStatus("Plan list refreshed.", Severity.Success);
        }
        catch (Exception ex)
        {
            if (await TryHandleAuthenticationChallengeAsync(ex))
            {
                return;
            }

            Logger.LogError(ex, "Failed to refresh plans for container '{ContainerId}'.", selectedContainer.Id);
            SetStatus(ToUserSafePlannerMessage(ex), Severity.Error);
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task OnFileChangedAsync(IBrowserFile? file)
    {
        if (file is null)
        {
            return;
        }

        ResetFlowState();

        selectedFileName = file.Name;

        await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        using var reader = new StreamReader(stream);
        csvContent = await reader.ReadToEndAsync();

        SetStatus("CSV file loaded. Click Validate and preview.", Severity.Info);
    }

    private async Task OnSelectedContainerChangedAsync(PlannerContainer? container)
    {
        if (selectedContainer?.Id == container?.Id)
        {
            return;
        }

        var hadPreview = preview is not null;
        selectedContainer = container;
        selectedPlan = null;
        plans.Clear();
        parseErrors.Clear();
        ResetExecutionState();
        MarkPreviewAsStale("Preview is stale because your selected container changed. Generate a fresh preview before execution.");

        if (selectedContainer is null)
        {
            if (!hadPreview)
            {
                SetStatus("Select a container to continue.", Severity.Info);
            }

            return;
        }

        isBusy = true;
        try
        {
            await WorkflowCoordinator.LoadPlansAsync(WorkflowState, CancellationToken.None);
        }
        catch (Exception ex)
        {
            if (await TryHandleAuthenticationChallengeAsync(ex))
            {
                return;
            }

            Logger.LogError(ex, "Failed to load plans for container '{ContainerId}'.", selectedContainer.Id);
            SetStatus(ToUserSafePlannerMessage(ex), Severity.Error);
        }
        finally
        {
            isBusy = false;
        }
    }

    private Task OnSelectedPlanChangedAsync(PlannerPlan? plan)
    {
        if (selectedPlan?.Id == plan?.Id)
        {
            return Task.CompletedTask;
        }

        var hadPreview = preview is not null;
        selectedPlan = plan;
        parseErrors.Clear();
        ResetExecutionState();
        MarkPreviewAsStale("Preview is stale because your selected plan changed. Generate a fresh preview before execution.");
        if (!hadPreview)
        {
            SetStatus(selectedPlan is null ? "Select a plan to continue." : null, Severity.Info);
        }

        return Task.CompletedTask;
    }

    private Task OnIgnoreExtraColumnsChanged(bool value)
    {
        if (ignoreExtraColumns == value)
        {
            return Task.CompletedTask;
        }

        ignoreExtraColumns = value;
        parseErrors.Clear();
        ResetExecutionState();
        MarkPreviewAsStale("Preview is stale because CSV options changed. Generate a fresh preview before execution.");
        return Task.CompletedTask;
    }

    private void ResetFlowState()
    {
        parseErrors.Clear();
        ResetPreviewState();
        ResetExecutionState();
        SetStatus(null, Severity.Info);
    }

    private void ResetPreviewState()
    {
        WorkflowState.PlanningViewModel = null;
        currentRequest = null;
        isPreviewStale = false;
    }

    private void ResetExecutionState()
    {
        WorkflowState.ExecutionReport = null;
    }

    private void InvalidatePreview(string message)
    {
        parseErrors.Clear();
        ResetPreviewState();
        ResetExecutionState();
        SetStatus(message, Severity.Warning);
    }

    private void MarkPreviewAsStale(string message)
    {
        if (preview is null || currentRequest is null)
        {
            return;
        }

        isPreviewStale = true;
        SetStatus(message, Severity.Warning);
    }

    private async Task BuildPreviewAsync()
    {
        if (isBusy)
        {
            return;
        }

        parseErrors.Clear();
        ResetPreviewState();
        ResetExecutionState();
        SetStatus(null, Severity.Info);

        isBusy = true;
        try
        {
            await WorkflowCoordinator.BuildPreviewAsync(WorkflowState, CancellationToken.None);
        }
        catch (Exception ex)
        {
            if (await TryHandleAuthenticationChallengeAsync(ex))
            {
                return;
            }

            Logger.LogError(ex, "Preview generation failed.");
            var userSafeMessage = ToUserSafePlannerMessage(ex);
            parseErrors.Add(new ImportValidationError(0, "System", userSafeMessage));
            SetStatus(userSafeMessage, Severity.Error);
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task ExecuteAsync()
    {
        if (!canExecute)
        {
            return;
        }

        isBusy = true;
        SetStatus(null, Severity.Info);
        try
        {
            await WorkflowCoordinator.ExecuteAsync(WorkflowState, CancellationToken.None);
        }
        catch (ImportToPlanner.Application.Exceptions.StaleImportPreviewException ex)
        {
            Logger.LogWarning(ex, "Execution blocked because preview is stale.");
            isPreviewStale = true;
            SetStatus(ex.Message, Severity.Warning);
        }
        catch (InvalidOperationException ex)
        {
            if (await TryHandleAuthenticationChallengeAsync(ex))
            {
                return;
            }

            Logger.LogWarning(ex, "Execution blocked by workflow constraints.");
            isPreviewStale = false;
            SetStatus(ToUserSafePlannerMessage(ex), Severity.Warning);
        }
        catch (Exception ex)
        {
            if (await TryHandleAuthenticationChallengeAsync(ex))
            {
                return;
            }

            Logger.LogError(ex, "Execution failed.");
            var userSafeMessage = ToUserSafePlannerMessage(ex);

            SetStatus(userSafeMessage, Severity.Error);
        }
        finally
        {
            isBusy = false;
        }
    }

    private void SetStatus(string? message, Severity severity)
    {
        statusMessage = message;
        statusMessageSeverity = severity;
    }

    private async Task<bool> TryHandleAuthenticationChallengeAsync(Exception exception)
    {
        if (exception is not Microsoft.Identity.Web.MicrosoftIdentityWebChallengeUserException)
        {
            return false;
        }

        Logger.LogWarning(exception, "Microsoft Graph token acquisition requires additional user interaction.");

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            NavigationManager.NavigateTo("MicrosoftIdentity/Account/SignIn", forceLoad: true);
            return true;
        }

        if (!HasTokenReauthenticationQueryFlag())
        {
            NavigationManager.NavigateTo(BuildInteractiveChallengeUri(authState.User), forceLoad: true);
            return true;
        }

        SetStatus(InteractiveTokenAcquisitionRequiredMessage, Severity.Warning);
        return true;
    }

    private bool HasTokenReauthenticationQueryFlag()
    {
        var query = new Uri(NavigationManager.Uri).Query;
        if (string.IsNullOrWhiteSpace(query))
        {
            return false;
        }

        var parsedQuery = QueryHelpers.ParseQuery(query);
        return parsedQuery.TryGetValue(TokenReauthenticationQueryKey, out var tokenReauthenticationValue)
               && string.Equals(tokenReauthenticationValue.ToString(), "1", StringComparison.Ordinal);
    }

    private void RemoveTokenReauthenticationQueryFlag()
    {
        var currentUri = new Uri(NavigationManager.Uri);
        var parsedQuery = QueryHelpers.ParseQuery(currentUri.Query);
        if (!parsedQuery.Remove(TokenReauthenticationQueryKey))
        {
            return;
        }

        var remainingQuery = parsedQuery
            .SelectMany(
                static pair => pair.Value,
                static (pair, value) => $"{Uri.EscapeDataString(pair.Key)}={Uri.EscapeDataString(value ?? string.Empty)}");

        var queryString = string.Join("&", remainingQuery);
        var targetUri = string.IsNullOrEmpty(queryString)
            ? currentUri.AbsolutePath
            : $"{currentUri.AbsolutePath}?{queryString}";

        if (!string.IsNullOrWhiteSpace(currentUri.Fragment))
        {
            targetUri += currentUri.Fragment;
        }

        NavigationManager.NavigateTo(targetUri, forceLoad: false, replace: true);
    }

    private string BuildInteractiveChallengeUri(System.Security.Claims.ClaimsPrincipal user)
    {
        ArgumentNullException.ThrowIfNull(user);

        var scopes = Configuration.GetSection("DownstreamApis:MicrosoftGraph:Scopes").Get<string[]>() ?? ["User.Read"];
        var challengeScope = string.Join(' ', scopes);
        var loginHint = user.FindFirst("preferred_username")?.Value ?? user.Identity?.Name ?? string.Empty;
        var redirectUri = $"/?{TokenReauthenticationQueryKey}=1";

        var encodedRedirectUri = Uri.EscapeDataString(redirectUri);
        var encodedScope = Uri.EscapeDataString(challengeScope);
        var encodedLoginHint = Uri.EscapeDataString(loginHint);

        return $"MicrosoftIdentity/Account/Challenge?redirectUri={encodedRedirectUri}&scope={encodedScope}&loginHint={encodedLoginHint}";
    }

    private static string ToUserSafePlannerMessage(Exception exception)
    {
        ArgumentNullException.ThrowIfNull(exception);

        if (exception is InvalidOperationException invalidOperationException)
        {
            if (invalidOperationException.Message.Contains("Unsupported account", StringComparison.OrdinalIgnoreCase))
            {
                return "Unsupported account type. Sign in with a supported work or school account.";
            }

            if (invalidOperationException.Message.Contains("administrator consent", StringComparison.OrdinalIgnoreCase))
            {
                return invalidOperationException.Message;
            }

            if (invalidOperationException.Message.Contains("tenant context", StringComparison.OrdinalIgnoreCase))
            {
                return "Tenant context could not be resolved for this hosted session. Sign in again and retry.";
            }
        }

        if (ImportWorkflowCoordinator.TryGetFailure(exception, out var failure))
        {
            return PlannerFailureMessageMapper.ToUserSafeMessage(failure);
        }

        return "An unexpected planner error occurred. Retry and check logs if the issue continues.";
    }

    private static string FormatContainer(PlannerContainer? container)
        => container is null ? string.Empty : $"{container.DisplayName} ({container.Type})";

    private static string FormatPlan(PlannerPlan? plan)
        => plan?.Title ?? string.Empty;

    private Task<IEnumerable<PlannerContainer>> SearchContainers(string value, CancellationToken cancellationToken)
        => SearchItems(
            value,
            containers,
            static (container, term) => container.DisplayName.Contains(term, StringComparison.OrdinalIgnoreCase)
                                        || container.Type.ToString().Contains(term, StringComparison.OrdinalIgnoreCase),
            cancellationToken);

    private Task<IEnumerable<PlannerPlan>> SearchPlans(string value, CancellationToken cancellationToken)
        => SearchItems(
            value,
            plans,
            static (plan, term) => plan.Title.Contains(term, StringComparison.OrdinalIgnoreCase),
            cancellationToken);

    private static Task<IEnumerable<TItem>> SearchItems<TItem>(
        string value,
        IEnumerable<TItem> source,
        Func<TItem, string, bool> match,
        CancellationToken cancellationToken)
    {
        cancellationToken.ThrowIfCancellationRequested();
        if (string.IsNullOrWhiteSpace(value))
        {
            return Task.FromResult(source);
        }

        return Task.FromResult(source.Where(item => match(item, value)));
    }

    private bool IsStepLocked(int step)
        => step switch
        {
            1 => false,
            2 => selectedContainer is null,
            3 => selectedContainer is null || selectedPlan is null,
            4 => selectedContainer is null || selectedPlan is null || string.IsNullOrWhiteSpace(csvContent),
            5 => executionResult is null && !canExecute,
            _ => throw new ArgumentOutOfRangeException(nameof(step), step, "Unknown step."),
        };

    private bool IsStepComplete(int step)
        => step switch
        {
            1 => selectedContainer is not null,
            2 => selectedPlan is not null,
            3 => !string.IsNullOrWhiteSpace(csvContent),
            4 => preview is not null && parseErrors.Count == 0 && !isPreviewStale && IsCurrentSelectionInSyncWithRequest(),
            5 => executionResult is not null,
            _ => throw new ArgumentOutOfRangeException(nameof(step), step, "Unknown step."),
        };

    private bool IsStepActive(int step) => ActiveStep.HasValue && ActiveStep.Value == step;

    private int GetStepElevation(int step)
        => IsStepLocked(step) ? 0 : IsStepActive(step) ? 2 : 1;

    private string GetStepClass(int step)
    {
        if (IsStepLocked(step))
        {
            return "step-card step-card--locked pa-4";
        }

        if (IsStepActive(step))
        {
            return "step-card step-card--active pa-4";
        }

        return "step-card step-card--complete pa-4";
    }

    private Color GetStepAvatarColour(int step)
    {
        if (IsStepComplete(step))
        {
            return Color.Success;
        }

        return IsStepActive(step) ? Color.Primary : Color.Default;
    }

    private Color GetStepSummaryColour(int step)
        => step == 5 && executionResult?.Errors.Count > 0
            ? Color.Warning
            : Color.Success;

    private MudFileUpload<IBrowserFile>? csvFileUpload;

    private async Task OpenCsvFilePickerAsync()
    {
        if (csvFileUpload is not null)
        {
            await csvFileUpload.OpenFilePickerAsync();
        }
    }

    private string GetStepAvatarContent(int step)
        => IsStepComplete(step)
            ? "✓"
            : step.ToString();

    private string GetStepSummary(int step)
        => step switch
        {
            1 => $"Container: {FormatContainer(selectedContainer)}",
            2 => $"Plan: {FormatPlan(selectedPlan)}",
            3 => $"CSV: {selectedFileName}",
            4 => "Preview generated and ready to execute.",
            5 => executionResult?.Errors.Count > 0
                ? "Execution finished with warnings."
                : "Execution completed successfully.",
            _ => string.Empty,
        };
}
