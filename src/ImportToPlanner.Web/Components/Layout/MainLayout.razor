@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h6">CSV to Planner Import</MudText>
            <MudText Typo="Typo.caption">Single-use utility for idempotent plan, bucket, and task creation with manual goal follow-up actions.</MudText>
        </MudStack>
        <MudSpacer />
        <AuthorizeView>
            <Authorized Context="authState">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.body2">@authState.User.Identity?.Name</MudText>
                    <MudButton Variant="Variant.Outlined" Color="Color.Inherit" OnClick="OnSignOutClicked">Sign out</MudButton>
                </MudStack>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnSignInClicked">Sign in</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudMainContent Class="pa-4">
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private void OnSignInClicked()
    {
        NavigationManager.NavigateTo("MicrosoftIdentity/Account/SignIn", forceLoad: true);
    }

    private void OnSignOutClicked()
    {
        var returnUrl = Uri.EscapeDataString(new Uri(NavigationManager.BaseUri).PathAndQuery);
        NavigationManager.NavigateTo($"MicrosoftIdentity/Account/SignOut?returnUrl={returnUrl}", forceLoad: true);
    }
}
