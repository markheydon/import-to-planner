@inherits LayoutComponentBase
@using ImportToPlanner.Web.Themes
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<MudThemeProvider @ref="themeProvider" Theme="@theme" IsDarkMode="isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="DrawerToggle" />
        <MudText Typo="Typo.h6">CSV to Planner Import</MudText>
        <MudSpacer />
        <MudMenu Label="@GetThemeMenuLabel()" Icon="@GetThemeMenuIcon()" Color="Color.Inherit" Variant="Variant.Text" Dense="true" AriaLabel="Theme mode">
            <MudMenuItem OnClick="@(() => SetThemeModeAsync(ThemeMode.Auto))">@GetThemeOptionLabel(ThemeMode.Auto)</MudMenuItem>
            <MudMenuItem OnClick="@(() => SetThemeModeAsync(ThemeMode.Light))">@GetThemeOptionLabel(ThemeMode.Light)</MudMenuItem>
            <MudMenuItem OnClick="@(() => SetThemeModeAsync(ThemeMode.Dark))">@GetThemeOptionLabel(ThemeMode.Dark)</MudMenuItem>
        </MudMenu>
        <AuthorizeView>
            <Authorized Context="authState">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.body2">@authState.User.Identity?.Name</MudText>
                    <MudButton Variant="Variant.Outlined" Color="Color.Inherit" OnClick="OnSignOutClicked">Sign out</MudButton>
                </MudStack>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnSignInClicked">Sign in</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pt-16 pa-4">
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private const string ThemeModeSessionKey = "import-to-planner-theme-mode";

    private bool drawerOpen = true;
    private bool isDarkMode;
    private bool isThemeInitialised;
    private ThemeMode themeMode = ThemeMode.Auto;
    private MudThemeProvider? themeProvider;
    private MudTheme theme = ImportToPlannerTheme.Default;

    protected override void OnInitialized()
    {
        base.OnInitialized();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (isThemeInitialised || themeProvider is null)
        {
            return;
        }

        string? mode;
        try
        {
            mode = await JSRuntime.InvokeAsync<string?>("importToPlannerThemeStorage.getThemeMode", ThemeModeSessionKey);
        }
        catch (InvalidOperationException)
        {
            return;
        }

        themeMode = ParseThemeMode(mode);
        await ApplyThemeModeAsync(themeMode);
        await themeProvider.WatchSystemPreference(OnSystemPreferenceChangedAsync);

        isThemeInitialised = true;
        await InvokeAsync(StateHasChanged);
    }

    private void DrawerToggle()
    {
        drawerOpen = !drawerOpen;
    }

    private void OnSignInClicked()
    {
        NavigationManager.NavigateTo("MicrosoftIdentity/Account/SignIn", forceLoad: true);
    }

    private void OnSignOutClicked()
    {
        var returnUrl = Uri.EscapeDataString(new Uri(NavigationManager.BaseUri).PathAndQuery);
        NavigationManager.NavigateTo($"MicrosoftIdentity/Account/SignOut?returnUrl={returnUrl}", forceLoad: true);
    }

    private async Task SetThemeModeAsync(ThemeMode mode)
    {
        await ApplyThemeModeAsync(mode);

        await JSRuntime.InvokeVoidAsync(
            "importToPlannerThemeStorage.setThemeMode",
            ThemeModeSessionKey,
            ToSessionValue(mode));
    }

    private Task OnSystemPreferenceChangedAsync(bool systemPrefersDarkMode)
    {
        if (themeMode is not ThemeMode.Auto)
        {
            return Task.CompletedTask;
        }

        isDarkMode = systemPrefersDarkMode;
        return InvokeAsync(StateHasChanged);
    }

    private async Task ApplyThemeModeAsync(ThemeMode mode)
    {
        themeMode = mode;
        if (mode is ThemeMode.Auto && themeProvider is not null)
        {
            isDarkMode = await themeProvider.GetSystemPreference();
            return;
        }

        isDarkMode = mode is ThemeMode.Dark;
    }

    private string GetThemeMenuIcon()
        => themeMode switch
        {
            ThemeMode.Auto => Icons.Material.Filled.BrightnessAuto,
            ThemeMode.Light => Icons.Material.Filled.LightMode,
            ThemeMode.Dark => Icons.Material.Filled.DarkMode,
            _ => Icons.Material.Filled.BrightnessAuto,
        };

    private string GetThemeMenuLabel()
        => $"Theme: {GetThemeModeDisplayName(themeMode)}";

    private string GetThemeOptionLabel(ThemeMode mode)
    {
        var label = GetThemeModeDisplayName(mode);
        return themeMode == mode ? $"✓ {label}" : label;
    }

    private static ThemeMode ParseThemeMode(string? mode)
        => mode?.ToLowerInvariant() switch
        {
            "light" => ThemeMode.Light,
            "dark" => ThemeMode.Dark,
            _ => ThemeMode.Auto,
        };

    private static string ToSessionValue(ThemeMode mode)
        => mode switch
        {
            ThemeMode.Light => "light",
            ThemeMode.Dark => "dark",
            _ => "auto",
        };

    private static string GetThemeModeDisplayName(ThemeMode mode)
        => mode switch
        {
            ThemeMode.Auto => "Auto",
            ThemeMode.Light => "Light",
            ThemeMode.Dark => "Dark",
            _ => "Auto",
        };

    private enum ThemeMode
    {
        Auto,
        Light,
        Dark,
    }
}
