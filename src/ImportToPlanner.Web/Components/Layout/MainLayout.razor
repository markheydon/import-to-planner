@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<FluentDesignTheme Mode="DesignThemeModes.System" />

<div class="app-shell">
    <header class="app-header">
        <h1>CSV to Planner Import</h1>
        <p>Single-use utility for idempotent plan, bucket, goal name, and task creation.</p>
        <AuthorizeView>
            <Authorized Context="authState">
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
                    <FluentLabel>@authState.User.Identity?.Name</FluentLabel>
                    <FluentButton OnClick="OnSignOutClicked" Appearance="Appearance.Neutral">Sign out</FluentButton>
                </FluentStack>
            </Authorized>
            <NotAuthorized>
                <FluentButton OnClick="OnSignInClicked" Appearance="Appearance.Accent">Sign in</FluentButton>
            </NotAuthorized>
        </AuthorizeView>
    </header>

    <main class="app-content">
        @Body
    </main>

    <FluentToastProvider />
    <FluentDialogProvider />
    <FluentMessageBarProvider />
    <FluentTooltipProvider />
    <FluentKeyCodeProvider />

    <div id="blazor-error-ui" data-nosnippet>
        An unhandled error has occurred.
        <a href="." class="reload">Reload</a>
        <span class="dismiss">x</span>
    </div>
</div>

@code {
    private void OnSignInClicked()
    {
        NavigationManager.NavigateTo("/MicrosoftIdentity/Account/SignIn", forceLoad: true);
    }

    private void OnSignOutClicked()
    {
        NavigationManager.NavigateTo("/MicrosoftIdentity/Account/SignOut?returnUrl=/", forceLoad: true);
    }
}
