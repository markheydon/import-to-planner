{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ImportToPlanner.Web (HTTPS)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build ImportToPlanner.Web",
      "program": "${workspaceFolder}/src/ImportToPlanner.Web/bin/Debug/net10.0/ImportToPlanner.Web.dll",
      "cwd": "${workspaceFolder}/src/ImportToPlanner.Web",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7129;http://localhost:5126",
        "ASPNETCORE_HTTPS_PORT": "7129"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    },
    {
      "name": "ImportToPlanner.Web (HTTP)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build ImportToPlanner.Web",
      "program": "${workspaceFolder}/src/ImportToPlanner.Web/bin/Debug/net10.0/ImportToPlanner.Web.dll",
      "cwd": "${workspaceFolder}/src/ImportToPlanner.Web",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5126"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}